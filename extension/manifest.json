{
  "manifest_version": 3,
  "name": "StatusInvest Latest Panel",
  "version": "0.1.0",
  "description": "Injeta um painel no StatusInvest com dados da sua API",
  "action": {
    "default_popup": "popup.html"
  },
  "background": {
    "service_worker": "bg.js"
  },
  "permissions": [
    "storage"
  ],
  "host_permissions": [
    "https://*.vercel.app/*"
  ]
}
