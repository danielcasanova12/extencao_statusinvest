# Exemplo de arquivo de configuração para a API (desenvolvimento local).
# Em produção (Vercel), estas variáveis devem ser configuradas no dashboard do projeto.

# URL de conexão com o banco de dados Postgres.
DATABASE_URL="postgres://user:password@host:port/database"

# Token secreto para proteger os endpoints de escrita (POST).
# Deixe em branco para desativar a autenticação.
API_TOKEN="seu_token_secreto_aqui"

# --- Configurações da Fórmula Mágica (calcular.js) ---

# Lista de tickers a serem excluídos (financeiros, holdings, etc.), separados por vírgula.
FINANCIAL_EXCLUSION_LIST="ITUB4,BPAC11,BBDC3,BBAS3,ITSA4,SANB11,B3SA3,BBSE3,CXSE3,PSSA3,MULT3,ALOS3,BPAN4,BNBR3,BRAP4,ABCB4,IGTA3,BRSR6,BMEB4,BAZA3,BSLI3,PLPL3,BEES3,BMGB4,LOGG3,PINE4,WIZC3,BPAR3,SYNE3,ITSA3,ITUB3,BBDC4,SANB3,SANB4,BPAC3,BRSR3,BRSR5,BMEB3,BEES4,PINE3,BRBI11,IRBR3,CIEL3"

# Filtros numéricos para a Fórmula Mágica.
MF_LIQ_MIN="1000000"
MF_MC_MIN="90000000"
MF_EBIT_MIN="1"
MF_MARGIN_EBIT_MIN="1"

# --- Configurações do Scraper do Investidor10 (scrape.js) ---

# Critérios do checklist a serem contados, separados por "|".
INV10_TARGET_CHECKS="Empresa nunca deu prejuízo (ano fiscal)|Empresa com lucro nos últimos 20 trimestres (5 anos)|Empresa possui dívida menor que patrimônio|Empresa apresentou crescimento de receita nos últimos 5 anos|Empresa apresentou crescimento de lucros nos últimos 5 anos|Empresa com mais de 5 anos de Bolsa|Empresa pagou +5% de dividendos/ano nos últimos 5 anos|Empresa possui ROE acima de 10%|Empresa possui liquidez diária acima de US$ 2M"
# Delay em milissegundos entre as requisições de scraping.
INV10_SCRAPE_DELAY="250"
# Mínimo de checks para o ranking FM+Inv10 (from-inv10.js).
FM_INV10_TRUE_MIN="5"